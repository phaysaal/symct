#include "common.h"
#include <stdlib.h>
#include <string.h>
#include <stdio.h>

/* ---- Global definitions ---- */
br_rsa_private_key g_key;

unsigned char *rsa_p = NULL;
unsigned char *rsa_q = NULL;
unsigned char *rsa_dp = NULL;
unsigned char *rsa_dq = NULL;
unsigned char *rsa_iq = NULL;

size_t len_p = 0, len_q = 0, len_dp = 0, len_dq = 0, len_iq = 0;

/* ---- Secure zero ---- */
void secure_zero(void *p, size_t n) {
    volatile unsigned char *v = (volatile unsigned char *)p;
    while (n--) *v++ = 0;
}

/* ---- Free everything ---- */
void free_rsa_bearssl_heap(void) {
    if (rsa_p) { secure_zero(rsa_p, len_p); free(rsa_p); rsa_p = NULL; len_p = 0; }
    if (rsa_q) { secure_zero(rsa_q, len_q); free(rsa_q); rsa_q = NULL; len_q = 0; }
    if (rsa_dp) { secure_zero(rsa_dp, len_dp); free(rsa_dp); rsa_dp = NULL; len_dp = 0; }
    if (rsa_dq) { secure_zero(rsa_dq, len_dq); free(rsa_dq); rsa_dq = NULL; len_dq = 0; }
    if (rsa_iq) { secure_zero(rsa_iq, len_iq); free(rsa_iq); rsa_iq = NULL; len_iq = 0; }
    memset(&g_key, 0, sizeof g_key);
}

/* ---- Load key directly into shared rsa_* buffers ---- */
int load_priv_from_pem_string(const char *pem) {
    br_pem_decoder_context pc;
    br_skey_decoder_context sk;

    br_pem_decoder_init(&pc);
    br_skey_decoder_init(&sk);

    /* Stream decoded DER directly into secret-key decoder */
    br_pem_decoder_setdest(&pc,
        (void (*)(void*, const void*, size_t)) &br_skey_decoder_push, &sk);

    const unsigned char *data = (const unsigned char*)pem;
    size_t len = strlen(pem), off = 0;

    while (off < len) {
        size_t used = br_pem_decoder_push(&pc, data + off, len - off);
        off += used;
        int ev = br_pem_decoder_event(&pc);
        if (ev == BR_PEM_ERROR) {
            fprintf(stderr, "PEM decoding error\n");
            return -1;
        }
        if (ev == BR_PEM_END_OBJ) break;
        if (used == 0) break;
    }

    if (br_skey_decoder_last_error(&sk) != 0)
        return -2;

    if (br_skey_decoder_key_type(&sk) != BR_KEYTYPE_RSA)
        return -3;

    const br_rsa_private_key *k = br_skey_decoder_get_rsa(&sk);
    if (!k)
        return -4;

    /* Allocate and copy into the global rsa_* buffers */
    len_p = k->plen; len_q = k->qlen;
    len_dp = k->dplen; len_dq = k->dqlen; len_iq = k->iqlen;

    rsa_p  = malloc(len_p);  memcpy(rsa_p,  k->p,  len_p);
    rsa_q  = malloc(len_q);  memcpy(rsa_q,  k->q,  len_q);
    rsa_dp = malloc(len_dp); memcpy(rsa_dp, k->dp, len_dp);
    rsa_dq = malloc(len_dq); memcpy(rsa_dq, k->dq, len_dq);
    rsa_iq = malloc(len_iq); memcpy(rsa_iq, k->iq, len_iq);

    g_key.p = rsa_p;  g_key.plen  = len_p;
    g_key.q = rsa_q;  g_key.qlen  = len_q;  
    g_key.dp = rsa_dp; g_key.dplen = len_dp;
    g_key.dq = rsa_dq; g_key.dqlen = len_dq;
    g_key.iq = rsa_iq; g_key.iqlen = len_iq;
    g_key.n_bitlen = k->n_bitlen;

    return 0;
}

void decode_rsa_bearssl(const br_rsa_private_key *key) {
    // Store key components in separate buffers for secret injection pattern
    
    len_p = key->plen;
    len_q = key->qlen;
    len_dp = key->dplen;
    len_dq = key->dqlen;
    len_iq = key->iqlen;
    
    rsa_p = malloc(len_p);
    memcpy(rsa_p, key->p, len_p);
    
    rsa_q = malloc(len_q);
    memcpy(rsa_q, key->q, len_q);
    
    rsa_dp = malloc(len_dp);
    memcpy(rsa_dp, key->dp, len_dp);
    
    rsa_dq = malloc(len_dq);
    memcpy(rsa_dq, key->dq, len_dq);
    
    rsa_iq = malloc(len_iq);
    memcpy(rsa_iq, key->iq, len_iq);
}

void encode_rsa_bearssl(br_rsa_private_key *key) {
    // Restore key components from stored buffers (simulating secret injection)
    key->p = rsa_p;
    key->q = rsa_q;
    key->dp = rsa_dp;
    key->dq = rsa_dq;
    key->iq = rsa_iq;
    key->plen = len_p;
    key->qlen = len_q;
    key->dplen = len_dp;
    key->dqlen = len_dq;
    key->iqlen = len_iq;
}

void free_rsa_bearssl(void) {
    if (rsa_p) free(rsa_p);
    if (rsa_q) free(rsa_q);
    if (rsa_dp) free(rsa_dp);
    if (rsa_dq) free(rsa_dq);
    if (rsa_iq) free(rsa_iq);
    
    rsa_p = rsa_q = rsa_dp = rsa_dq = rsa_iq = NULL;
}

void test_end () {
    free_rsa_bearssl();
    free_rsa_bearssl_heap();
}
