# Exclude everything by default
*

# ---- Python scripts ----
!runbench.py
!callstack2source.py
!merge_reports.py
!runall.py
!keylen.json
!clean_bins.sh
!strip_paths.sh

# ---- OCaml plugin (source only) ----
!plugin/
plugin/_build/

# ---- Binsec configs (only 32-bit ini files) ----
!binsec/32/
binsec/32/**/store*/
binsec/32/**/claude/

# ---- Benchmark: common inputs ----
!benchmark/common/

# ---- Benchmark: 32-bit libraries ----
!benchmark/32/

# Exclude build artifacts inside benchmark
benchmark/32/**/*.o
benchmark/32/**/*.core
benchmark/32/**/bin/
benchmark/32/**/*~
benchmark/32/**/*.bak

# ---- Artifact: Dockerfile and custom binsec ----
!artifact/Dockerfile
!artifact/binsec.tar.xz
